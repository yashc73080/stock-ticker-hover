{
  "manifest_version": 3,
  "name": "Hover-to-Ticker",
  "version": "1.0.0",
  "description": "Hover over company names on any webpage to see real-time stock data.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://finnhub.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/compromise.min.js",
        "companies.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
